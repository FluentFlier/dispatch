{
  "name": "content-os",
  "version": "0.1.0",
  "description": "Content OS: private content command center for creators",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prod:check": "bash scripts/prod-ready-check.sh",
    "demo:seed": "npx tsx scripts/seed-demo-user.ts",
    "signals:smoke": "bash scripts/signals-e2e-smoke.sh",
    "intelligence:health": "npx tsx scripts/intelligence-health.ts",
    "intelligence:run": "npx tsx scripts/intelligence-health.ts --run --remote",
    "hooks:research": "npx tsx scripts/research-hooks.ts",
    "hooks:listen": "npx tsx scripts/research-hooks.ts --all",
    "landing:assets": "npx tsx scripts/generate-landing-assets.ts",
    "ui:sync": "bash scripts/sync-dispatch-ui.sh",
    "db:intelligence": "bash scripts/apply-all-intelligence.sh",
    "db:agent": "bash scripts/apply-agent-integration.sh",
    "db:admin-ops": "npx @insforge/cli db import db/admin-ops.sql -y",
    "brain:backfill": "npx @insforge/cli db import db/backfill-creator-brain.sql -y",
    "deploy:vercel": "bash scripts/deploy-vercel.sh",
    "eval:smoke": "promptfoo eval --env-file .env.local -c evals/promptfooconfig.smoke.ts -o evals/out/smoke.json",
    "eval:full": "promptfoo eval --env-file .env.local -c evals/promptfooconfig.full.ts -o evals/out/full.json --no-cache",
    "eval:gate": "npx tsx evals/compare-baseline.ts evals/out/full.json",
    "eval:baseline": "npx tsx evals/compare-baseline.ts evals/out/full.json --write",
    "canary:generate": "npx tsx evals/generate-canary.ts",
    "eval:canary": "promptfoo eval --env-file .env.local -c evals/promptfooconfig.canary.ts -o evals/out/canary.json"
  },
  "dependencies": {
    "@composio/core": "^0.13.1",
    "@hello-pangea/dnd": "^17.0.0",
    "@huggingface/inference": "^4.13.20",
    "@insforge/sdk": "^1.2.2",
    "@langfuse/otel": "5.9.1",
    "@langfuse/tracing": "5.9.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/sdk-trace-node": "2.9.0",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@remotion/player": "^4.0.443",
    "@tabler/icons-react": "^3.44.0",
    "@vercel/functions": "3.7.5",
    "apify-client": "^2.23.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "next": "14.2.21",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "qss": "^3.0.0",
    "react": "^18.3.1",
    "react-archer": "^5.1.0",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "remotion": "^4.0.443",
    "tailwind-merge": "^3.5.0",
    "twilio": "^6.0.2",
    "twitter-api-v2": "^1.29.0",
    "unipile-node-sdk": "^1.9.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.21",
    "js-yaml": "5.2.1",
    "postcss": "^8.4.49",
    "promptfoo": "0.121.18",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
