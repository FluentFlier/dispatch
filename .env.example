# InsForge
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
# Service role for cron/background (recommended in production)
INSFORGE_SERVICE_ROLE_KEY=

# App URL (OAuth callbacks, Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token encryption (32 bytes hex for AES-256-GCM — generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# Social publishing: unipile (default when UNIPILE_API_KEY set) or direct
SOCIAL_PROVIDER_MODE=unipile
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_WEBHOOK_SECRET=

# Twitter / X (direct mode OAuth)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Instagram (via Facebook Graph API)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# Cron (Bearer token for /api/cron/*)
CRON_SECRET=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Optional: forward analytics events
ANALYTICS_WEBHOOK_URL=

# Optional: Supermemory semantic search (Creator Brain uses InsForge by default)
SUPERMEMORY_API_KEY=

# === DISPATCH INTELLIGENCE (Hook Intelligence + Closed Loop SaaS) ===
# Apify for production-scale reliable mining (X + LinkedIn). GStack only for dev loops.
APIFY_TOKEN=
USE_APIFY=true          # set false or omit to force gstack dev paths

# Usage events (optional rich table for analytics + future Stripe meters)
# Table created via db/hooks-intelligence.sql + production-delta

# To run continuous free dev mining (thousands of loops):
#   npm run hooks:listen
#   bash scripts/continuous-research-loop.sh
# Then set USE_APIFY=true + real token for consumer prod.

# --- LLM provider (text generation + voice evaluation) ---
# Provider-agnostic: any OpenAI-compatible /chat/completions endpoint works.
# Swap providers by changing these three values only — no code changes.
#   Groq (testing):  LLM_BASE_URL=https://api.groq.com/openai/v1   LLM_MODEL=llama-3.3-70b-versatile
#   OpenAI:          LLM_BASE_URL=https://api.openai.com/v1        LLM_MODEL=gpt-4o-mini
#   HuggingFace:     LLM_BASE_URL=https://router.huggingface.co/v1 LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
#   InsForge AI:     LLM_BASE_URL=<insforge-ai-gateway>/v1         LLM_MODEL=anthropic/claude-sonnet-4.5
# If LLM_* are unset, text generation falls back to the legacy HUGGINGFACE_API_KEY path.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# HuggingFace — still used for AI-slop detection, embeddings, and audio transcription
# (these are HF-specific ML tasks Groq/OpenAI do not provide). Keep funded for those.
HUGGINGFACE_API_KEY=

# Legacy (deprecated, no longer used for generation — kept to avoid breaking old envs)
AI_API_KEY=
