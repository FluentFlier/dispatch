# InsForge
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=
# Service role for cron/background (recommended in production)
INSFORGE_SERVICE_ROLE_KEY=

# App URL (OAuth callbacks, Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token encryption (32 bytes hex for AES-256-GCM — generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# Social publishing: unipile (default when UNIPILE_API_KEY set) or direct
SOCIAL_PROVIDER_MODE=unipile
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_WEBHOOK_SECRET=

# Twitter / X (direct mode OAuth)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Instagram (via Facebook Graph API)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# Composio (Signals: Slack alerts, Gmail outreach, Calendar follow-ups)
COMPOSIO_API_KEY=
COMPOSIO_SLACK_AUTH_CONFIG_ID=
COMPOSIO_GMAIL_AUTH_CONFIG_ID=
COMPOSIO_GOOGLECALENDAR_AUTH_CONFIG_ID=
# Optional: dedicated HMAC secret for Composio OAuth state (falls back to CRON_SECRET)
COMPOSIO_STATE_SECRET=

# Cron (Bearer token for /api/cron/*)
CRON_SECRET=

# Content OS Signals (GTM module)
# Ingest: webhook (Clay/Zapier) + Unipile poll by default. Apify optional for Signals only.
SIGNALS_INGEST_MODE=auto          # auto | webhook | unipile | apify
SIGNALS_USE_APIFY=false           # true only if you want Apify for Signals poll (Hook Intelligence is separate)
SIGNALS_INGEST_SECRET=            # Bearer for POST /api/signals/ingest (falls back to CRON_SECRET)
SIGNALS_MAX_POSTS_PER_SOURCE=5    # cost guard per source per poll
# APIFY_TOKEN required for live X/LinkedIn ingest (see below)
# DEMO_SEED_ENABLED=true       # allow POST /api/demo/seed in production
# DEMO_SEED_SECRET=            # optional Bearer for ops seed (falls back to CRON_SECRET)
# NEXT_PUBLIC_DEMO_MODE=true   # show demo hint on login page
# SIGNALS_ALLOW_SEED=true  # optional: allow demo seed + /api/signals/seed in production

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Optional: forward analytics events
ANALYTICS_WEBHOOK_URL=

# Optional: Supermemory semantic search (Creator Brain uses InsForge by default)
SUPERMEMORY_API_KEY=

# === DISPATCH INTELLIGENCE (Hook Intelligence + Closed Loop SaaS) ===
# Apify for production-scale reliable mining (X + LinkedIn). GStack only for dev loops.
APIFY_TOKEN=
USE_APIFY=true          # set false or omit to force gstack dev paths

# Usage events (optional rich table for analytics + future Stripe meters)
# Table created via db/hooks-intelligence.sql + production-delta

# To run continuous free dev mining (thousands of loops):
#   npm run hooks:listen
#   bash scripts/continuous-research-loop.sh
# Then set USE_APIFY=true + real token for consumer prod.

# AI provider (OpenAI-compatible key — swap to HuggingFace, Anthropic, etc if needed)
AI_API_KEY=
