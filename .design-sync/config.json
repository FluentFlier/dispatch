{
  "projectId": "b39bb9a2-7e92-4f22-bb72-cb8696a760b1",
  "shape": "package",
  "pkg": "content-os",
  "globalName": "ContentOS",
  "entry": ".design-sync/ds-entry.ts",
  "srcDir": "src/components/ui",
  "tsconfig": ".design-sync/tsconfig.json",
  "cssEntry": ".design-sync/.cache/ds-compiled.css",
  "guidelinesGlob": ["DESIGN.md"],
  "readmeHeader": ".design-sync/conventions.md",
  "overrides": {
    "Modal": { "cardMode": "single", "viewport": "560x400" },
    "Drawer": { "cardMode": "single", "viewport": "560x500" },
    "LeadsPage": { "cardMode": "single", "viewport": "1280x800" },
    "CalendarPage": { "cardMode": "single", "viewport": "1280x800" },
    "AnalyticsPage": { "cardMode": "single", "viewport": "1280x800" },
    "IdeasPage": { "cardMode": "single", "viewport": "1280x800" },
    "LibraryPage": { "cardMode": "single", "viewport": "1280x800" },
    "SettingsPage": { "cardMode": "single", "viewport": "1280x800" },
    "GeneratePage": { "cardMode": "single", "viewport": "1280x800" },
    "InboxPage": { "cardMode": "single", "viewport": "1280x800" },
    "VoiceLabPage": { "cardMode": "single", "viewport": "1280x800" },
    "VideoStudioPage": { "cardMode": "single", "viewport": "1280x800" },
    "OnboardingPage": { "cardMode": "single", "viewport": "1280x800" },
    "SeriesPage": { "cardMode": "single", "viewport": "1280x800" },
    "StoryBankPage": { "cardMode": "single", "viewport": "1280x800" },
