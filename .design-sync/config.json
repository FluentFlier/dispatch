  "docsMap": {
    "LeadsPage": ".design-sync/docs/LeadsPage.md",
    "CalendarPage": ".design-sync/docs/CalendarPage.md",
    "AnalyticsPage": ".design-sync/docs/AnalyticsPage.md",
    "IdeasPage": ".design-sync/docs/IdeasPage.md",
    "LibraryPage": ".design-sync/docs/LibraryPage.md",
    "SettingsPage": ".design-sync/docs/SettingsPage.md",
